{
  "name": "langchain-ai",
  "version": "1.0.0",
  "description": "Study workspace for LangChain, LangGraph, and LangSmith with Node.js and TypeScript",
  "homepage": "https://github.com/ndanilo/langchain-ai#readme",
  "bugs": {
    "url": "https://github.com/ndanilo/langchain-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ndanilo/langchain-ai.git"
  },
  "license": "ISC",
  "author": "Danilo",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "langchain:server": "npx @langchain/langgraph-cli dev",
